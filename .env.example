# ============================================================
# IBP — مثال متغيرات البيئة
# انسخه إلى .env واملأ القيم محلياً. لا تضع أسراراً حقيقية هنا.
# قاعدة المشروع: لا أسرار في الكود، بيانات وهمية فقط في التطوير.
# ============================================================

# ----- عام -----
NODE_ENV=development

# ----- قاعدة البيانات (PostgreSQL) -----
# داخل docker-compose يكون المضيف "postgres"؛ محلياً يكون "localhost".
POSTGRES_USER=ibp
POSTGRES_PASSWORD=change_me_local_only
POSTGRES_DB=ibp_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ibp:change_me_local_only@localhost:5432/ibp_dev?schema=public

# ----- Redis (الكاش/الطوابير) -----
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ----- الـ API (NestJS) -----
API_PORT=4000
# أصول مسموح بها للـ CORS (مفصولة بفواصل)
CORS_ORIGINS=http://localhost:3000

# ----- الواجهة (Next.js) -----
WEB_PORT=3000
# عنوان الـ API كما يراه المتصفح
NEXT_PUBLIC_API_URL=http://localhost:4000

# ----- المصادقة (يُستخدم في المرحلة 1 — ضع قيمة محلية فقط) -----
JWT_SECRET=replace_with_local_dev_secret_only
JWT_EXPIRES_IN=15m

# ----- التخزين (Object Storage) — حيادي المزوّد (المرحلة 5) -----
# يتحوّل من MinIO محلي إلى S3/Alibaba OSS/GCS بتغيير المتغيّرات فقط (Cloud Portability).
STORAGE_DRIVER=s3                 # s3 | alibaba_oss | google_cloud_storage | minio
STORAGE_ENDPOINT=                 # محلياً http://minio:9000 ، أو s3.me-central-1.amazonaws.com
STORAGE_REGION=me-central-1
STORAGE_BUCKET=ibp-dev
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
# صلاحية الرابط الموقّت بالثواني — معيار أمني: 5 دقائق
PRESIGNED_URL_EXPIRY_SECONDS=300
