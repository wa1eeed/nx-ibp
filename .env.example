# ============================================================
# IBP — مثال متغيرات البيئة
# انسخه إلى .env واملأ القيم محلياً. لا تضع أسراراً حقيقية هنا.
# قاعدة المشروع: لا أسرار في الكود، بيانات وهمية فقط في التطوير.
# ============================================================

# ----- عام -----
NODE_ENV=development

# ----- البذرة (اختيار المحتوى المزروع) -----
# غير مضبوط (تطوير محلي) = بذرة ديمو كاملة (مستأجرون وهميون + بيانات شبه واقعية).
# SEED_MODE=production = بذرة إقلاع الإنتاج: مرجعيات فقط (باقات/كتالوج/مزوّدون) + سوبر أدمن من البيئة. لا بيانات وهمية.
# SEED_MODE=demo = يسمح ببذرة الديمو على بيئة منشورة (NODE_ENV=production) صراحةً (لبيئة الديمو/التجريبية).
# SEED_MODE=
# سوبر أدمن المنصة — إلزامي عند SEED_MODE=production (لا كلمة مرور افتراضية في الإنتاج؛ لا تُعاد كتابتها إن وُجد الحساب).
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASSWORD=                   # 12 حرفًا فأكثر
PLATFORM_ADMIN_NAME=مالك المنصة

# ----- قاعدة البيانات (PostgreSQL) -----
# داخل docker-compose يكون المضيف "postgres"؛ محلياً يكون "localhost".
POSTGRES_USER=ibp
POSTGRES_PASSWORD=change_me_local_only
POSTGRES_DB=ibp_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ibp:change_me_local_only@localhost:5432/ibp_dev?schema=public

# قاعدة اختبار منفصلة (اختياري لكن مُوصى به): أنشئ ملف .env.test (غير مُتعقَّب) يحوي فقط
# DATABASE_URL لقاعدة ibp_test كي لا تلوّث الاختبارات بيانات التطوير. ثم: pnpm --filter @ibp/db test:setup
# DATABASE_URL=postgresql://ibp:change_me_local_only@localhost:5432/ibp_test?schema=public

# ----- Redis (الكاش/الطوابير) -----
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ----- الـ API (NestJS) -----
API_PORT=4000
# أصول مسموح بها للـ CORS (مفصولة بفواصل)
CORS_ORIGINS=http://localhost:3000

# ----- الواجهة (Next.js) -----
WEB_PORT=3000
# عنوان الـ API كما يراه المتصفح
NEXT_PUBLIC_API_URL=http://localhost:4000

# ----- المصادقة (يُستخدم في المرحلة 1 — ضع قيمة محلية فقط) -----
JWT_SECRET=replace_with_local_dev_secret_only
JWT_EXPIRES_IN=15m

# ----- صلابة الدخول (Track G/P0 — قفل القوّة الغاشمة، مدعوم بـ Redis) -----
# عدد المحاولات الفاشلة قبل القفل المؤقّت، ومدّة النافذة بالثواني (افتراضي 15 دقيقة)
LOGIN_MAX_FAILURES=8
LOGIN_LOCK_WINDOW_SEC=900

# ----- التخزين (Object Storage) — حيادي المزوّد، متوافق S3 (المرحلة A1) -----
# يتحوّل من المحلي إلى S3/R2/MinIO/Alibaba OSS بتغيير المتغيّرات فقط (بلا تبعية SDK).
# السحابي ⇒ روابط موقّتة مباشِرة للدلو (لا تمرّ البايتات بالـ API) ثم تأكيد بـ POST /documents/:id/confirm
STORAGE_DRIVER=local              # local (تطوير) | s3 | r2 | minio | alibaba_oss
STORAGE_LOCAL_DIR=.storage        # مجلد التخزين للسائق المحلي (مهمَل من git)
STORAGE_ENDPOINT=                 # s3: https://s3.me-central-1.amazonaws.com · R2: https://<acc>.r2.cloudflarestorage.com
STORAGE_REGION=me-central-1       # إقليم AWS؛ لـ R2 استخدم: auto
STORAGE_BUCKET=ibp-dev
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_FORCE_PATH_STYLE=true     # true لـ R2/MinIO (path-style) · false لـ virtual-hosted في AWS
# صلاحية الرابط الموقّت بالثواني — معيار أمني: 5 دقائق
PRESIGNED_URL_EXPIRY_SECONDS=300

# ----- ZATCA (Fatoora) -----
# مفتاح تشفير بيانات الاعتماد at-rest (AES-256-GCM). ولّد 32 بايت: openssl rand -base64 32
ZATCA_ENC_KEY=replace_with_base64_32_bytes
ZATCA_DEFAULT_ENV=SANDBOX

# ----- فوترة الاشتراكات (المرحلة B2 — بوّابة الدفع) -----
# sandbox (تطوير/اختبار، بلا شبكة) | tap (إنتاج عبر Tap.company)
BILLING_GATEWAY=sandbox
BILLING_CURRENCY=SAR
BILLING_WEBHOOK_SECRET=sandbox_secret   # سرّ توقيع الـ webhook الوهمي (sandbox فقط)
# Tap (https://developers.tap.company) — مطلوبة عند BILLING_GATEWAY=tap
TAP_SECRET_KEY=                          # sk_test_… أو sk_live_…
TAP_API_URL=https://api.tap.company/v2
# عناوين عامة لبناء روابط العودة/الـ webhook (تقع على الواجهة والـ API)
APP_PUBLIC_URL=http://localhost:3000     # أصل الواجهة (redirect بعد الدفع)
API_PUBLIC_URL=http://localhost:4000     # أصل الـ API (post/webhook من البوّابة)

# ----- الإشعارات (المرحلة H — SMS/Email) -----
# sandbox (تطوير/اختبار، تسجيل فقط) | live (إرسال فعلي: Taqnyat + Resend)
NOTIFY_GATEWAY=sandbox
# Taqnyat (SMS — https://api.taqnyat.sa) — مطلوبة عند NOTIFY_GATEWAY=live
TAQNYAT_API_KEY=
TAQNYAT_SENDER=IBP                        # اسم المُرسِل المعتمد لدى Taqnyat
TAQNYAT_API_URL=https://api.taqnyat.sa
# Resend (Email — https://resend.com) — مطلوبة عند NOTIFY_GATEWAY=live
RESEND_API_KEY=                           # re_…
NOTIFY_EMAIL_FROM=IBP <no-reply@example.sa>  # المُرسِل (نطاق مُوثَّق في Resend)
RESEND_API_URL=https://api.resend.com
