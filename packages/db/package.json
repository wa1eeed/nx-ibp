{
  "name": "@ibp/db",
  "version": "0.0.0",
  "private": true,
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "generate": "prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "reset": "dotenv -e ../../.env -- prisma migrate reset --force",
    "build": "prisma generate",
    "lint": "echo \"(db) no lint\"",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@ibp/shared": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.16.5",
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  }
}
