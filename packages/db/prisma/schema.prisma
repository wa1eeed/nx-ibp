// schema.prisma — نموذج بيانات منصة IBP
// المصدر الحقيقي الوحيد للبنية. كل الجداول التشغيلية مفلترة بـ tenantId.
// هذا أساس قابل للتوسّع — أضف الحقول التفصيلية مع كل مرحلة في ROADMAP.md.

generator client {
  provider = "prisma-client-js"
  // مخرج مخصّص داخل الحزمة لتفادي تعارض pnpm في monorepo؛
  // يُعاد تصديره عبر packages/db/index.js
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// المنصة: المستأجرون والاشتراكات والصلاحيات (مستوى السوبر أدمن)
// ============================================================

// مالك المنصة (سوبر أدمن) — عابر للمستأجرين، بلا tenantId (لا يخضع لعزل Prisma).
model PlatformAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  fullName     String
  passwordHash String?
  mfaSecret    String? // سرّ TOTP (Base32) — يُضبط عند الإعداد
  mfaEnabled   Boolean  @default(false) // المصادقة الثنائية مفعّلة
  createdAt    DateTime @default(now())
}

model Tenant {
  id            String       @id @default(cuid())
  name          String
  nameEn        String?
  crNumber      String? // السجل التجاري لشركة الوساطة
  unifiedNumber String? // الرقم الموحد للمنشأة (700-series، 10 أرقام)
  vatNumber     String? // الرقم الضريبي (15 رقمًا)
  phone         String? // رقم التواصل (جوال سعودي 05XXXXXXXX)
  // العنوان الوطني (لفاتورة ZATCA — عنوان البائع)
  buildingNo    String? // رقم المبنى (4 أرقام)
  street        String? // اسم الشارع
  district      String? // الحي
  city          String? // المدينة
  postalCode    String? // الرمز البريدي (5 أرقام)
  status        TenantStatus @default(ACTIVE)
  billingModel  BillingModel @default(PASS_THROUGH) // نموذج التحقق: عبر حسابات الشركة نفسها (PASS_THROUGH) أو عبر المنصة برسوم+هامش (RESELLER)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  subscription    Subscription?
  users           User[]
  clientUsers     ClientUser[]
  branches        Branch[]
  config          TenantConfig?
  emailSettings   TenantEmailSettings?
  paymentSettings TenantPaymentSettings?
  portalPayments  PortalPayment[]
  targets         Target[]
  insurers        Insurer[]
  wallets         Wallet[]

  // العلاقات التشغيلية — كلها مرتبطة بـ tenantId كمفتاح أجنبي لفرض العزل والتكامل المرجعي
  roles                Role[]
  clients              Client[]
  policyRequests       PolicyRequest[]
  policies             Policy[]
  installments         Installment[]
  complaints           Complaint[]
  amlAssessments       AmlRiskAssessment[]
  amlScreenings        AmlScreening[]
  suspiciousReports    SuspiciousReport[]
  coverNotes           CoverNote[]
  bankAccounts         BankAccount[]
  bankTransactions     BankTransaction[]
  budgetLines          BudgetLine[]
  serviceRequests      ServiceRequest[]
  claims               Claim[]
  chartOfAccounts      ChartOfAccount[]
  vouchers             Voucher[]
  invoices             Invoice[]
  commissions          Commission[]
  verificationChecks   VerificationCheck[]
  documents            Document[]
  auditLogs            AuditLog[]
  requestBlockRows     RequestBlockRow[]
  slips                Slip[]
  quotations           Quotation[]
  endorsements         Endorsement[]
  costCenters          CostCenter[]
  debitNotes           DebitNote[]
  creditNotes          CreditNote[]
  zatcaConfig          TenantZatcaConfig?
  billingDocuments     BillingDocument[]
  subscriptionInvoices SubscriptionInvoice[]
  departments          Department[]
  storage              TenantStorage?
  notificationSettings NotificationSetting[]
  notificationPrefs    NotificationPreference[]
  notifications        Notification[]
  deals                Deal[]
  crmActivities        CrmActivity[]
  crmTasks             CrmTask[]
  producers            Producer[]
  formTemplates        FormTemplate[]
}

// إعداد إشعار — NULL tenantId = افتراضي المنصة (يديره سوبر أدمن المنصة)؛
// قيمة tenantId = تخصيص شركة (يديره مالك الحساب). القناة تُفعَّل/تُعطَّل والنص قابل للتعديل.
model NotificationSetting {
  id           String   @id @default(cuid())
  tenantId     String? // NULL ⇒ افتراضي المنصة
  tenant       Tenant?  @relation(fields: [tenantId], references: [id])
  eventKey     String // welcome | policy_issued | debit_note | tax_invoice | request_ack | claim_ack | renewal_reminder
  channelEmail Boolean  @default(true)
  channelSms   Boolean  @default(false)
  subject      String?
  body         String   @db.Text
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
}

/// إشعار داخل المنصة (in-app) لمستقبِل واحد: موظف (userId) أو عميل بوّابة (clientId).
/// معزول بالمستأجر. يُنشأ تلقائيًا عند إطلاق حدث مُفعَّل، ويُعرَض في جرس الإشعارات.
model Notification {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  userId    String? // مستقبِل موظف (staff)
  clientId  String? // مستقبِل عميل (client — بوّابة العميل)
  eventKey  String
  audience  String // client | staff
  title     String
  body      String    @db.Text
  readAt    DateTime? // NULL ⇒ غير مقروء
  createdAt DateTime  @default(now())

  @@index([tenantId, userId, readAt])
  @@index([tenantId, clientId, readAt])
}

/// صفقة/فرصة CRM — تمرّ بمراحل (Pipeline)، قابلة للإسناد لموظف، ومرتبطة بعميل. معزولة بالمستأجر.
model Deal {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  clientId          String? // العميل المرتبط
  title             String
  stage             String    @default("new") // new | contacted | quoting | proposal | negotiation
  status            String    @default("open") // open | won | lost
  value             Decimal?  @db.Decimal(14, 2) // القسط المتوقّع
  productLineCode   String?
  assigneeId        String? // الموظف المُسنَد إليه
  lostReason        String?
  requestId         String? // ربط بطلب تأمين عند التحويل (won)
  createdById       String?
  // إثراء الفرصة البيعية (Sales Lead) وفق معايير الوساطة (أويسس)
  exclusivity       String? // exclusive | non_exclusive (حالة BOR — وسيط السجل)
  estimatedPremium  Decimal?  @db.Decimal(14, 2) // القسط التقديري (يُقارَن بقسط الإصدار)
  expectedCloseDate DateTime? // تاريخ الإغلاق المتوقّع
  source            String? // direct | producer (مصدر الفرصة)
  producerName      String? // اسم المنتِج/الوسيط الفرعي عند source=producer
  currentInsurer    String? // شركة التأمين الحالية (للأعمال المُحوَّلة/التجديد)
  lossRatio         Decimal?  @db.Decimal(6, 2) // نسبة الخسارة الحالية %
  preferredInsurers String[] // شركات التأمين المفضّلة للعميل
  notes             String? // ملاحظات/متطلبات
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([tenantId, stage])
  @@index([tenantId, assigneeId])
}

/// نشاط/ملاحظة CRM polymorphic — سجلّ تفاعلات وملاحظات على أي كيان (صفقة/عميل/وثيقة/مطالبة).
/// يخدم أيضًا الخط الزمني في صفحة العميل والموظف.
model CrmActivity {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  entityType String // deal | client | policy | claim | request | service
  entityId   String
  type       String   @default("note") // note | call | email | meeting | stage_change | task | reply
  visibility String   @default("internal") // internal (staff-only) | client (shown in client portal)
  body       String   @db.Text
  authorId   String?
  createdAt  DateTime @default(now())

  @@index([tenantId, entityType, entityId])
}

/// مهمة/تذكير CRM — قابلة للإسناد + تاريخ استحقاق + أولوية. تُطلق إشعارًا عند الإسناد.
model CrmTask {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  title          String
  entityType     String? // مرتبطة بكيان اختياريًا
  entityId       String?
  assigneeId     String?
  dueDate        DateTime?
  priority       String    @default("normal") // low | normal | high
  status         String    @default("open") // open | done
  createdById    String?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
  reminderSentAt DateTime? // تذكير الاستحقاق أُرسِل (idempotency للمجدول)

  @@index([tenantId, assigneeId, status])
  @@index([tenantId, dueDate])
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED
}

enum BillingModel {
  PASS_THROUGH // التحقق عبر حسابات الشركة في يقين/نفاذ (المنصة لا تفوتر التحقق)
  RESELLER // التحقق عبر المنصة: تُطبَّق الرسوم + هامش المنصة (محفظة مسبقة الشحن)
}

model Plan {
  id               String         @id @default(cuid())
  code             String         @unique // basic | premium | enterprise
  name             String
  seatLimit        Int // الحد الأقصى للمستخدمين (المقاعد)
  priceMonthly     Decimal        @db.Decimal(12, 2) // السعر لكل مستخدم/شهر
  priceYearly      Decimal        @db.Decimal(12, 2) // السعر لكل مستخدم/سنة
  trialDays        Int            @default(0) // مدة التجربة المجانية (0 = بلا تجربة)
  slaResponseHours Int? // زمن استجابة الدعم المتعهَّد به (ساعات؛ 24=يوم عمل) — P1-A
  entitlements     Entitlement[]
  subscriptions    Subscription[]
}

// الصلاحية/الحد لميزة ضمن باقة: مشمول/حصّة/رسوم/إضافة/معطّل
model Entitlement {
  id           String          @id @default(cuid())
  planId       String
  plan         Plan            @relation(fields: [planId], references: [id])
  featureKey   String // مثال: module.claims | dynamic_form | upload.maxFileMb
  mode         EntitlementMode
  quota        Int? // للحصص (عدد طلبات/أدوار...)
  numericValue Decimal?        @db.Decimal(12, 2) // لحدود مثل ميغابايت الرفع
  unitFee      Decimal?        @db.Decimal(12, 2) // لرسوم الاستخدام

  @@unique([planId, featureKey])
}

enum EntitlementMode {
  INCLUDED
  QUOTA
  METERED
  ADDON
  DISABLED
}

model Subscription {
  id        String          @id @default(cuid())
  tenantId  String          @unique
  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  planId    String
  plan      Plan            @relation(fields: [planId], references: [id])
  cycle     BillingCycle    @default(MONTHLY)
  seatsUsed Int             @default(0)
  startedAt DateTime        @default(now())
  renewsAt  DateTime?
  addons    AddonPurchase[]
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

model AddonPurchase {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  addonKey       String // extra_seats | module.claims | api_integration ...
  quantity       Int          @default(1)
  createdAt      DateTime     @default(now())
}

enum BillingInvoiceStatus {
  PENDING // صدرت بانتظار الدفع
  PAID // اكتمل الدفع (CAPTURED)
  FAILED // فشل/رُفض الدفع
  VOID // أُلغيت
}

/// فاتورة اشتراك المنصّة (مدفوعات SaaS عبر بوّابة دفع) — منفصلة تمامًا عن
/// فواتير التأمين (Invoice/BillingDocument). معزولة بالمستأجر.
model SubscriptionInvoice {
  id              String               @id @default(cuid())
  tenantId        String
  tenant          Tenant               @relation(fields: [tenantId], references: [id])
  planCode        String
  cycle           BillingCycle
  amount          Decimal              @db.Decimal(12, 2)
  currency        String               @default("SAR")
  status          BillingInvoiceStatus @default(PENDING)
  gateway         String // sandbox | tap
  gatewayChargeId String? // معرّف الشحنة لدى البوّابة (chg_…)
  redirectUrl     String?              @db.Text // رابط صفحة الدفع المستضافة
  reference       String? // مرجعنا الداخلي المُمرَّر للبوّابة
  periodStart     DateTime?
  periodEnd       DateTime?
  paidAt          DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([tenantId])
  @@index([gatewayChargeId])
}

// ============================================================
// المستخدمون والصلاحيات (RBAC)
// ============================================================

model User {
  id                  String      @id @default(cuid())
  tenantId            String
  tenant              Tenant      @relation(fields: [tenantId], references: [id])
  email               String
  fullName            String
  passwordHash        String? // bcrypt — يُضبط عند الإنشاء/الدعوة (المرحلة 1)
  mfaSecret           String? // سرّ TOTP (Base32) — يُضبط عند بدء الإعداد
  mfaEnabled          Boolean     @default(false) // المصادقة الثنائية مفعّلة لهذا المستخدم
  status              UserStatus  @default(ACTIVE)
  roleId              String?
  role                Role?       @relation(fields: [roleId], references: [id])
  departmentId        String?
  department          Department? @relation(fields: [departmentId], references: [id])
  // نطاق المنتجات: أكواد فروع التأمين المسموح بها لهذا المستخدم. فارغة = بلا تقييد (كل الفروع)
  // — متوافق رجعيًا: السلوك الافتراضي بلا تغيير ولا يتأثّر أي مستخدم قائم.
  allowedProductLines String[]    @default([])
  commissionRate      Decimal?    @db.Decimal(6, 3) // نسبة عمولة/حافز الموظف (% من عمولة الوساطة) — لمندوبي المبيعات
  createdAt           DateTime    @default(now())

  @@unique([tenantId, email])
  @@index([tenantId])
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

model Role {
  id                    String       @id @default(cuid())
  tenantId              String // الأدوار قابلة للتخصيص لكل مستأجر
  tenant                Tenant       @relation(fields: [tenantId], references: [id])
  name                  String // المدير العام، مدير المبيعات ...
  isPreset              Boolean      @default(false)
  permissions           Permission[]
  users                 User[]
  defaultForDepartments Department[]
  notificationPrefs     NotificationPreference[]

  @@index([tenantId])
}

/// تفضيل إشعارات لكل **دور × نوع إشعار موظفين** (§9.1) — طبقة فوق التوجيه بالصلاحيات.
/// الدلالة **opt-out**: غياب الصفّ = مُفعَّل (يستقبل الدور هذا النوع)؛ صفّ enabled=false = الدور **كتم** النوع.
/// يُطبَّق على إشعارات البثّ للوحدة (notifyStaff)؛ إشعارات الإسناد المباشر (notifyUser) تتجاوزه دائمًا.
model NotificationPreference {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  eventKey  String // مفتاح نوع إشعار موظفين (staff_*)
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@unique([roleId, eventKey])
  @@index([tenantId])
}

/// قسم تنظيمي هرمي داخل شركة الوساطة (المرحلة C1). معزول بالمستأجر.
/// قد يحمل دورًا افتراضيًا (defaultRole) يُطبَّق على من يُسند إليه ما لم يُتجاوز فرديًا.
model Department {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  name          String
  parentId      String?
  parent        Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children      Department[] @relation("DeptHierarchy")
  defaultRoleId String?
  defaultRole   Role?        @relation(fields: [defaultRoleId], references: [id])
  members       User[]
  createdAt     DateTime     @default(now())

  @@index([tenantId])
}

// صلاحية موديول واحد: وصول/إضافة/تعديل/حذف
model Permission {
  id        String  @id @default(cuid())
  roleId    String
  role      Role    @relation(fields: [roleId], references: [id])
  module    String // sales | clients | production | finance ...
  canAccess Boolean @default(false)
  canCreate Boolean @default(false)
  canEdit   Boolean @default(false)
  canDelete Boolean @default(false)
  canRevert Boolean @default(false) // E4 — صلاحية التراجع خطوة للوراء عن إجراءات الوحدة (للمشرف)

  @@unique([roleId, module])
}

// ============================================================
// التهيئة لكل مستأجر
// ============================================================

model TenantConfig {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  enabledProducts String[] // أكواد الفروع المفعّلة من كتالوج المنتجات
  sequenceFormats Json? // صيغ أرقام التسلسل
  emailTemplates  Json? // قوالب الإيميلات
  approvalChains  Json? // سلاسل الاعتماد
  securityPolicy  Json? // سياسة الأمان على مستوى الشركة (إلزام MFA…)
  branding        Json? // الشعار والألوان
}

model Branch {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  code     String // RUH | KBR ...
  name     String

  @@unique([tenantId, code])
}

// ============================================================
// إدارة شركات التأمين (المؤمِّنون) — سجلّ + اتفاقيات/نِسب عمولة + تسوية + حساب بنكي
// ============================================================
// كيان «شركة تأمين» كمرجع لكل مستأجر: النسبة المتّفق عليها، دورة التسوية (مهلة السداد)،
// الحساب البنكي للتوريد، وبيانات الترخيص/التواصل. تُربط تشغيليًا بالوثائق عبر الاسم.
model Insurer {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  name            String // الاسم (يطابق insurerName على الوثائق)
  nameEn          String?
  code            String? // رمز داخلي اختياري
  licenseNo       String? // رقم ترخيص هيئة التأمين
  vatNumber       String? // الرقم الضريبي (15 رقمًا) — للمشتري في فاتورة العمولة
  nationalAddress String? // العنوان الوطني (لفاتورة ZATCA)
  commissionRate  Decimal? @db.Decimal(6, 3) // نسبة العمولة المتّفق عليها (%)
  settlementDays  Int? // دورة التسوية: مهلة توريد الأقساط (أيام)
  bankName        String?
  iban            String? // حساب التوريد
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  notes           String?
  status          String   @default("active") // active | inactive
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
}

// ============================================================
// أهداف الأداء (Targets) — أهداف إنتاج للمنتِجين/فروع التأمين — P1-B
// ============================================================
// «الفعلي» يُحسب من بيانات الإنتاج القائمة (الوثائق المُصدَرة) — لا بيانات جديدة.
model Target {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  scope       String // producer | line (فرع التأمين)
  scopeRefId  String // معرّف المنتِج أو كود فرع المنتج
  metric      String // premium | policies | commissions
  period      String // month | quarter | year
  periodStart DateTime // بداية الفترة (يُحسب المدى منها)
  targetValue Decimal  @db.Decimal(14, 2)
  createdBy   String
  createdAt   DateTime @default(now())

  @@index([tenantId])
}

// ============================================================
// إعدادات البريد لكل مستأجر (BYO Resend + fallback مركزي) — P0-A
// ============================================================
// كل مستأجر يرسل من إيميله الرسمي عبر حساب Resend خاص (BYO)، مع fallback مركزي
// يضمن عدم الانقطاع، وترقية تلقائية إلى وضع المستأجر بعد التحقّق من النطاق (DNS).
model TenantEmailSettings {
  id                    String    @id @default(cuid())
  tenantId              String    @unique
  tenant                Tenant    @relation(fields: [tenantId], references: [id])
  fromEmail             String? // العنوان الرسمي للمرسِل (noreply@broker.sa)
  fromName              String? // اسم العرض (شركة الوساطة)
  resendApiKeyEncrypted String? // مفتاح Resend مشفّر at-rest (AES-256-GCM) — لا plaintext أبداً
  domain                String? // يُستخرج من fromEmail
  resendDomainId        String? // معرّف النطاق في Resend
  verificationStatus    String    @default("unconfigured") // unconfigured | pending | verified | failed
  dnsRecords            Json? // سجلّات DNS للعرض (SPF/DKIM/DMARC)
  sendingMode           String    @default("fallback") // fallback | tenant
  lastVerifiedAt        DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// إعدادات بوّابة الدفع للمستأجر (BYO) — تستقبل شركة الوساطة مدفوعات عملائها
// عبر بوّابة واحدة (Tap أو Moyasar) بمفاتيحها الخاصة. المفتاح السري مشفّر at-rest.
model TenantPaymentSettings {
  id                 String   @id @default(cuid())
  tenantId           String   @unique
  tenant             Tenant   @relation(fields: [tenantId], references: [id])
  provider           String   @default("none") // none | tap | moyasar
  secretKeyEncrypted String? // المفتاح السري مشفّر at-rest (AES-256-GCM) — لا plaintext أبداً
  publicKey          String? // المفتاح العام (غير سرّي — يُستخدم في الواجهة/التحويل)
  enabled            Boolean  @default(false)
  currency           String   @default("SAR")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// عملية دفع إلكتروني من بوّابة العميل مقابل إشعار مدين — تربط شحنة البوّابة بالذمّة.
// عند نجاح الدفع يُنشأ سند قبض (RCV) تلقائيًا ويُطبَّق شلال الأقساط.
model PortalPayment {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  clientId         String
  debitNoteId      String
  amount           Decimal  @db.Decimal(14, 2)
  currency         String   @default("SAR")
  gateway          String // tap | moyasar | sandbox
  gatewayChargeId  String?
  redirectUrl      String?
  status           String   @default("PENDING") // PENDING | PAID | FAILED
  receiptVoucherId String? // سند القبض المُنشأ عند نجاح الدفع
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId])
  @@index([gatewayChargeId])
  @@index([clientId])
}

// ============================================================
// كتالوج المنتجات (من الملحق 6.A) — مرجعي على مستوى المنصة
// ============================================================

model ProductClass {
  id    String        @id @default(cuid())
  code  String        @unique // MED | MOT | ENG ...
  name  String
  lines ProductLine[]
}

model ProductLine {
  id         String       @id @default(cuid())
  classId    String
  class      ProductClass @relation(fields: [classId], references: [id])
  code       String // GMI | MIC | CAR ...
  name       String
  formSchema FormSchema?
}

// مخطط النموذج الديناميكي لكل فرع (versioned)
model FormSchema {
  id         String      @id @default(cuid())
  lineId     String      @unique
  line       ProductLine @relation(fields: [lineId], references: [id])
  version    Int         @default(1)
  baseFields Json // الحقول الأساسية
  blocks     Json // الكتل المتكررة المفعّلة: members/vehicles/locations/shipments
}

// ============================================================
// التشغيل: العملاء والإصدار والخدمة والمطالبات
// ============================================================

model Client {
  id                String              @id @default(cuid())
  tenantId          String
  tenant            Tenant              @relation(fields: [tenantId], references: [id])
  code              String? // معرّف تجاري مقروء (CLI-RUH-2026-1001)
  type              ClientType
  name              String
  crNumber          String? // للمنشآت
  nationalId        String? // للأفراد
  email             String?
  phone             String? // جوال سعودي 05XXXXXXXX (رقم التواصل الأساسي)
  landline          String? // هاتف ثابت 01XXXXXXXX (اختياري)
  contactName       String? // اسم شخص التواصل لدى العميل
  city              String?
  nationalAddress   String?
  // حقول معيارية لوساطة التأمين (إثراء سجل المؤمن له)
  vatNumber         String? // الرقم الضريبي (15 رقماً للمنشآت)
  relationStatus    String? // captive | non_captive (أسير/غير أسير)
  legalForm         String? // llc | joint_stock | partnership | jv | joint_liability | sole_proprietor | individual
  source            String? // direct | producer (مصدر العميل)
  producerName      String? // اسم المنتِج/الوسيط الفرعي عند source=producer
  businessActivity  String? // النشاط التجاري
  iban              String? // للاسترداد/الدفعات
  // آلية التحصيل الافتراضية لوثائق هذا العميل — تُبصَم على الوثيقة عند الإصدار:
  //   collect_full = الوسيط يُحصّل كامل القسط ويحتجز الأمانة ويورّدها للمؤمِّن (الافتراضي، متوافق رجعيًا)
  //   direct       = العميل يدفع القسط للمؤمِّن مباشرةً؛ الوسيط يُفوتر عمولته فقط (لا أمانة ولا تسوية)
  collectionModel   String              @default("collect_full")
  contacts          Json? // قائمة جهات الاتصال: [{ name, title, phone, email }]
  accountManagerId  String? // مدير الحساب المُعيَّن (نقطة تواصل العميل — معيار الوساطة)
  status            String?             @default("active")
  complianceStatus  ComplianceStatus    @default(PENDING)
  complianceNote    String?
  // مكافحة غسل الأموال (AML) — آخر تقييم مخاطر (المصدر الكامل في AmlRiskAssessment)
  amlRiskLevel      String? // low | medium | high
  amlRiskScore      Int? // 0..100 (مشتقّ من عوامل الخطر)
  amlRiskAssessedAt DateTime?
  amlReviewDue      DateTime? // موعد إعادة التقييم الدوري (EDD أقصر للمخاطر العالية)
  createdAt         DateTime            @default(now())
  erasedAt          DateTime? // إتلاف/إخفاء PII (حق المحو — PDPL) — يُبقي الهيكل المالي
  erasedBy          String? // المستخدم الذي نفّذ المحو (سجلّ الإتلاف)
  policyRequests    PolicyRequest[]
  portalUsers       ClientUser[]
  AmlRiskAssessment AmlRiskAssessment[]
  AmlScreening      AmlScreening[]
  SuspiciousReport  SuspiciousReport[]

  // تفرّد لكل مستأجر (NULL لا يتعارض ⇒ الأفراد بلا CR والمنشآت بلا هوية مسموح بهما)
  @@unique([tenantId, code])
  @@unique([tenantId, crNumber])
  @@unique([tenantId, nationalId])
  @@index([tenantId])
}

/// مستخدم بوّابة العميل (المرحلة 8ب) — مبدأ مستقلّ عن موظفي المستأجر.
/// نطاقه `client`: يخضع لعزل المستأجر (tenantId) + يرى بيانات عميله فقط (clientId).
model ClientUser {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id])
  email        String   @unique
  fullName     String
  passwordHash String?
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([clientId])
}

enum ClientType {
  CORPORATE
  INDIVIDUAL
}

enum ComplianceStatus {
  PENDING
  APPROVED
  REJECTED
}

model PolicyRequest {
  id                  String            @id @default(cuid())
  tenantId            String
  tenant              Tenant            @relation(fields: [tenantId], references: [id])
  sequenceNo          String? // SL/POL-RUH-MED-2025-1001
  clientId            String
  client              Client            @relation(fields: [clientId], references: [id])
  productLineCode     String
  status              RequestStatus     @default(DRAFT)
  base                Json // الحقول الأساسية المعبّأة (محقّقة ضد FormSchema)
  details             Json? // حقول خاصة بالفرع
  renewedFromPolicyId String? // الوثيقة المنتهية التي بُني عليها هذا الطلب (سلسلة التجديد)
  blockRows           RequestBlockRow[]
  slips               Slip[]
  createdAt           DateTime          @default(now())

  @@index([tenantId])
  @@index([clientId])
  @@index([renewedFromPolicyId])
}

enum RequestStatus {
  DRAFT
  QUOTING // أُرسل الـ Slip وتُجمع العروض
  AWARDED // أمر إسناد العميل (Firm Order) — جاهز للإصدار (المرحلة 4ب)
  UNDER_REVIEW
  FINANCE_REVIEW
  APPROVED
  REJECTED
  ISSUED
}

// مخزن عام موحّد لصفوف الكتل المتكررة لأي منتج (تابعون/مركبات/مواقع/شحنات/أرواح/مسافرون…)
// مدفوع بمخطط FormSchema بدل جداول ثابتة — يستوعب تنوّع منتجات التأمين.
model RequestBlockRow {
  id        String        @id @default(cuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  requestId String
  request   PolicyRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  blockKey  String // members | vehicles | locations | shipments | lives | travellers
  rowIndex  Int
  data      Json

  @@index([tenantId])
  @@index([requestId, blockKey])
}

// ============================================================
// المرحلة 4أ — الاكتتاب الفني: طلب الأسعار (Slip/RFQ) والعروض
// ============================================================

model Slip {
  id                    String        @id @default(cuid())
  tenantId              String
  tenant                Tenant        @relation(fields: [tenantId], references: [id])
  requestId             String
  request               PolicyRequest @relation(fields: [requestId], references: [id])
  sequenceNo            String? // RFQ-MED-2026-1001
  status                SlipStatus    @default(DRAFT)
  insurers              String[] // شركات التأمين المستهدفة
  notes                 String?
  selectedQuotationId   String? // العرض المختار (Firm Order)
  // عرض العروض على العميل عبر البوّابة + قراره (§4.1)
  presentedAt           DateTime? // متى عُرضت العروض على العميل
  presentedQuotationIds String[] // العروض المنتقاة للعرض على العميل (يختار الوسيط ما يُظهره)
  clientDecision        String? // pending | accepted | declined
  clientDecidedAt       DateTime?
  acceptedQuotationId   String? // العرض الذي قبله العميل (= أمر الإسناد)
  clientDecisionNote    String? // ملاحظة العميل (سبب الرفض مثلاً)
  createdAt             DateTime      @default(now())
  quotations            Quotation[]

  @@index([tenantId])
  @@index([requestId])
}

enum SlipStatus {
  DRAFT
  SENT
  QUOTED
  SELECTED
  CLOSED
}

// عرض شركة تأمين — هجين: حقول معيارية للمقارنة الآلية + نص حر للشروط
model Quotation {
  id                   String          @id @default(cuid())
  tenantId             String
  tenant               Tenant          @relation(fields: [tenantId], references: [id])
  slipId               String
  slip                 Slip            @relation(fields: [slipId], references: [id], onDelete: Cascade)
  insurerName          String
  // ----- الحقول المعيارية (Structured — لجدول المقارنة الآلي) -----
  rate                 Decimal?        @db.Decimal(6, 3) // نسبة %
  sumInsured           Decimal?        @db.Decimal(16, 2) // مبلغ التأمين (أساس القسط/العمولة)
  premium              Decimal?        @db.Decimal(14, 2) // القسط الصافي
  policyFees           Decimal?        @db.Decimal(14, 2) // رسوم الوثيقة
  vat                  Decimal?        @db.Decimal(14, 2)
  totalPremium         Decimal?        @db.Decimal(14, 2) // الإجمالي = صافي + رسوم + ضريبة
  commissionRate       Decimal?        @db.Decimal(6, 3) // نسبة عمولة الوسيط %
  commissionAmount     Decimal?        @db.Decimal(14, 2) // مبلغ عمولة الوسيط (Brokerage)
  commissionVat        Decimal?        @db.Decimal(14, 2) // ضريبة عمولة الوساطة (15% دائمًا — مخرجات الوسيط)
  deductible           Decimal?        @db.Decimal(14, 2) // مبلغ التحمل
  limit                Decimal?        @db.Decimal(16, 2) // حد التغطية
  validUntil           DateTime?
  coverFields          Json? // حقول معيارية إضافية خاصة بالمنتج
  // ----- القسم الحر (Free Text) -----
  generalRemarks       String?
  additionalConditions String?
  status               QuotationStatus @default(RECEIVED)
  createdAt            DateTime        @default(now())

  @@index([tenantId])
  @@index([slipId])
}

enum QuotationStatus {
  RECEIVED
  SELECTED
  REJECTED
}

// ملحق وثيقة (إضافة/حذف/تعديل/إلغاء) — الكيان جاهز، ودورته الكاملة في 4ب
model Endorsement {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  policyId      String
  policy        Policy        @relation(fields: [policyId], references: [id])
  sequenceNo    String? // POL-…/E1
  type          String // addition | deletion | amendment | cancellation
  effectiveDate DateTime?
  premiumDelta  Decimal?      @db.Decimal(14, 2)
  details       Json?
  status        RequestStatus @default(DRAFT)
  createdAt     DateTime      @default(now())

  @@index([tenantId])
  @@index([policyId])
}

// الوثيقة المُصدَرة (المرحلة 4ب): تنشأ من طلب AWARDED وتمرّ باعتماد فني ← مالي.
model Policy {
  id                    String        @id @default(cuid())
  tenantId              String
  tenant                Tenant        @relation(fields: [tenantId], references: [id])
  requestId             String?
  clientId              String?
  productLineCode       String?
  insurerName           String?
  sequenceNo            String? // POL-RUH-MED-2026-1001
  premium               Decimal?      @db.Decimal(14, 2) // القسط الصافي
  vat                   Decimal?      @db.Decimal(14, 2)
  totalPremium          Decimal?      @db.Decimal(14, 2)
  commissionRate        Decimal?      @db.Decimal(6, 3)
  commissionAmount      Decimal?      @db.Decimal(14, 2)
  // حقول معيارية للوثيقة (إثراء سجل الوثيقة)
  insurerPolicyNo       String? // رقم الوثيقة الرسمي الصادر من المؤمِّن
  issuanceType          String        @default("POLICY") // POLICY | RENEWAL | ENDORSEMENT
  issueDate             DateTime? // تاريخ الإصدار (يختلف عن بدء التغطية)
  policyFees            Decimal?      @db.Decimal(14, 2) // رسوم إصدار الوثيقة
  sumInsured            Decimal?      @db.Decimal(16, 2) // مبلغ التأمين الإجمالي
  paymentTerms          String? // شروط/جدول السداد
  producerName          String? // المنتِج (الوسيط الفرعي) — نص حرّ (توافق خلفي)
  producerId            String? // مرجع سجلّ المنتِجين
  producerCommission    Decimal?      @db.Decimal(14, 2) // عمولة المنتِج (من عمولة الوسيط)
  salespersonId         String? // الموظف (مندوب المبيعات) المُستحِقّ للعمولة الداخلية
  salespersonCommission Decimal?      @db.Decimal(14, 2) // عمولة/حافز الموظف (تُحتسب من عمولة الوساطة عند الإصدار)
  // آلية التحصيل المبصومة عند الإصدار (collect_full | direct) — مصدر الحقيقة للترحيل المالي.
  // NULL على الوثائق القديمة ⇒ تُعامَل كـ collect_full (السلوك التاريخي). لا تتأثّر بتغيير إعداد العميل لاحقًا.
  collectionModel       String?
  status                PolicyStatus  @default(TECHNICAL_REVIEW)
  // E2 — سلاسل الاعتماد: مفاتيح خطوات الاعتماد الإضافية المتبقّية (بين الفني والمالي).
  // فارغ = السلسلة الافتراضية (فني ⇒ مالي)؛ يُملأ من TenantConfig.approvalChains عند الموافقة الفنية،
  // ويُفرَّغ خطوةً خطوة؛ الاعتماد المالي محجوب حتى تُفرَّغ (وثيقة معزولة بالمستأجر).
  pendingApprovals      String[]      @default([])
  startDate             DateTime?
  endDate               DateTime?
  renewalRemindedAt     DateTime? // تذكير التجديد أُرسِل (idempotency للمجدول)
  createdAt             DateTime      @default(now())
  endorsements          Endorsement[]

  @@index([tenantId])
  @@index([requestId])
  @@index([tenantId, status, endDate])
  @@index([tenantId, producerId])
}

enum PolicyStatus {
  TECHNICAL_REVIEW // بانتظار الموافقة الفنية (Underwriter)
  FINANCE_REVIEW // بانتظار الاعتماد المالي (Accountant)
  ISSUED // مُصدَرة (بعد ترحيل القيد والإشعار والفاتورة)
  REJECTED
  CANCELLED
}

// طلب خدمة العميل (المرحلة 6): إضافة/حذف/تعديل على وثيقة سارية
model ServiceRequest {
  id         String        @id @default(cuid())
  tenantId   String
  tenant     Tenant        @relation(fields: [tenantId], references: [id])
  sequenceNo String? // RQ-2026-1001
  clientId   String?
  policyId   String?
  type       String // addition | deletion | amendment | inquiry | renewal
  subject    String?
  status     ServiceStatus @default(OPEN)
  priority   String        @default("normal") // low | normal | high | urgent
  assigneeId String? // الموظف المُسنَد إليه معالجة الطلب
  details    Json?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @default(now()) @updatedAt

  @@index([tenantId])
  @@index([tenantId, assigneeId, status])
}

enum ServiceStatus {
  OPEN
  IN_PROGRESS
  SENT_TO_INSURER
  CLOSED
}

// المطالبات (المرحلة 6): استقبال ← تحقّق ← رفع للمؤمِّن ← تسوية ← إغلاق
model Claim {
  id            String      @id @default(cuid())
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  sequenceNo    String? // CL-2026-1001
  clientId      String?
  policyId      String?
  insurerName   String?
  incidentDate  DateTime?
  claimedAmount Decimal?    @db.Decimal(14, 2)
  deductible    Decimal?    @db.Decimal(14, 2)
  settledAmount Decimal?    @db.Decimal(14, 2)
  status        ClaimStatus @default(RECEIVED)
  details       Json?
  createdAt     DateTime    @default(now())

  @@index([tenantId])
}

enum ClaimStatus {
  RECEIVED
  UNDER_REVIEW
  SUBMITTED
  SETTLED
  CLOSED
  REJECTED
}

// سجلّ الشكاوى (متطلب هيئة التأمين) — كل شكوى بفئتها ومصدرها ومهلة حلّها (SLA)
// وإسنادها وتصعيدها للهيئة عند اللزوم. أساس التقرير التنظيمي الدوري.
model Complaint {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  sequenceNo  String? // CMP-2026-1001
  clientId    String?
  policyId    String?
  category    String // pricing | claims | service | sales_conduct | billing | data_privacy | other
  source      String // phone | email | portal | walk_in | regulator | social
  subject     String
  description String
  status      String    @default("open") // open | investigating | resolved | escalated | closed
  priority    String    @default("normal") // urgent | high | normal | low
  assigneeId  String? // الموظف المسؤول
  dueDate     DateTime? // مهلة الحلّ (SLA)
  resolution  String? // ملخّص المعالجة
  resolvedAt  DateTime?
  escalated   Boolean   @default(false) // صُعِّدت لهيئة التأمين
  escalatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
}

// ── مكافحة غسل الأموال وتمويل الإرهاب (AML/CFT) — متطلّب ترخيصي (هيئة التأمين/ساما) ──

// تقييم مخاطر AML لكل عميل (عوامل خطر موزونة ⇒ درجة/مستوى؛ يحكم شدّة العناية الواجبة EDD ودورية المراجعة).
model AmlRiskAssessment {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  clientId     String
  client       Client    @relation(fields: [clientId], references: [id])
  level        String // low | medium | high
  score        Int // 0..100 (مشتقّ من العوامل)
  factors      Json // { pep, highRiskCountry, cashIntensive, complexStructure, sanctionsHit, adverseMedia, nonResident }
  rationale    String?
  assessedById String?
  reviewDue    DateTime? // موعد إعادة التقييم الدوري
  createdAt    DateTime  @default(now())

  @@index([tenantId])
  @@index([tenantId, clientId])
}

// سجلّ فرز العقوبات/الأشخاص المعرّضين سياسياً (PEP) — كل عملية فرز ونتيجتها والتصرّف حيالها.
model AmlScreening {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id])
  screenedName String
  lists        String // القوائم المفحوصة (CSV): un,ofac,eu,local,pep
  result       String // clear | potential_match | confirmed_match
  matches      Json? // [{ list, matchedName, score, type }]
  disposition  String   @default("pending") // pending | cleared (إيجابي كاذب) | escalated (تطابق حقيقي ⇒ بلاغ)
  note         String?
  screenedById String?
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, clientId])
}

// سجلّ بلاغات الاشتباه (STR) المرفوعة للوحدة (SAFIU) — دورة حياة: مسودّة ← مرفوع ← مغلق.
model SuspiciousReport {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  sequenceNo  String? // STR-2026-1001
  clientId    String?
  client      Client?   @relation(fields: [clientId], references: [id])
  indicators  Json // مؤشّرات الاشتباه (مصفوفة رموز)
  subject     String
  description String
  status      String    @default("draft") // draft | filed | closed
  reference   String? // مرجع البلاغ لدى الوحدة
  filedAt     DateTime?
  filedById   String?
  closedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
}

// حساب بنكي للوساطة (§1.6) — قد يكون للشركة عدّة حسابات؛ التسوية تُطابق كشف البنك بسندات النظام.
model BankAccount {
  id             String            @id @default(cuid())
  tenantId       String
  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  name           String // «الجاري — الراجحي»
  bankName       String?
  iban           String?
  accountNo      String?
  currency       String            @default("SAR")
  openingBalance Decimal           @default(0) @db.Decimal(16, 2)
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  transactions   BankTransaction[]

  @@index([tenantId])
}

// حركة كشف البنك المستوردة (§1.6) — تُطابَق يدويًا/آليًا بسند نظام (RCV/PYV) لإتمام التسوية.
model BankTransaction {
  id               String      @id @default(cuid())
  tenantId         String
  tenant           Tenant      @relation(fields: [tenantId], references: [id])
  bankAccountId    String
  bankAccount      BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  txnDate          DateTime
  description      String
  amount           Decimal     @db.Decimal(16, 2) // موجب = إيداع (وارد) · سالب = سحب (صادر)
  reference        String?
  matchedVoucherId String? // السند المطابق (Voucher)
  status           String      @default("unmatched") // unmatched | matched | ignored
  createdAt        DateTime    @default(now())

  @@index([tenantId])
  @@index([tenantId, bankAccountId])
}

/// §1.8 — بند موازنة تقديرية (Budget vs Actual): مبلغ مُقدَّر لحساب من شجرة الحسابات في فترة مالية.
/// الفعلي يُشتقّ آليًا من حركة السندات على الحساب ضمن نطاق تاريخ الفترة. معزول بالمستأجر.
model BudgetLine {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  fiscalYear  Int // السنة المالية (مثال 2026)
  period      String // annual | Q1 | Q2 | Q3 | Q4
  accountCode String // كود الحساب في شجرة الحسابات (17 رقمًا)
  amount      Decimal  @db.Decimal(18, 2) // المبلغ المُقدَّر (موجب)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, fiscalYear, period, accountCode])
  @@index([tenantId, fiscalYear])
}

// مذكرة التغطية المؤقتة (Cover Note / Binder — §4.2): تغطية فورية عند أمر الإسناد قبل إصدار الوثيقة،
// بصلاحية زمنية محدودة. تُلغى/تُستبدَل تلقائيًا عند إصدار الوثيقة الكاملة.
model CoverNote {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  sequenceNo      String? // COV-2026-1001
  requestId       String // الطلب المُسنَد (AWARDED) المبنيّة عليه
  clientId        String?
  quotationId     String? // العرض المصدر لشروط التغطية
  insurerName     String?
  productLineCode String?
  sumInsured      Decimal?  @db.Decimal(16, 2)
  premium         Decimal?  @db.Decimal(14, 2)
  totalPremium    Decimal?  @db.Decimal(14, 2)
  deductible      Decimal?  @db.Decimal(14, 2)
  limit           Decimal?  @db.Decimal(16, 2)
  startDate       DateTime?
  endDate         DateTime?
  validUntil      DateTime // انتهاء صلاحية المذكرة المؤقتة
  status          String    @default("active") // active | superseded (صدرت الوثيقة) | expired | cancelled
  policyId        String? // الوثيقة التي حلّت محلّها عند الإصدار
  notes           String?
  issuedById      String?
  createdAt       DateTime  @default(now())

  @@index([tenantId])
  @@index([tenantId, requestId])
}

// ============================================================
// المالية — بنية مهيّأة للمرحلة 4ب (المنطق يُبنى لاحقاً)
// ============================================================

// شجرة الحسابات: كود 17 رقماً. المستوى 1/2 مقفل (توحيد تقارير الهيئة)،
// المستوى 3 تحليلي ديناميكي (رفع Excel للهجرة). فصل داخل/خارج الميزانية.
model ChartOfAccount {
  id           String           @id @default(cuid())
  tenantId     String
  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  code         String // 17 رقماً
  name         String
  level        Int              @default(3) // 1 | 2 | 3
  parentId     String?
  parent       ChartOfAccount?  @relation("CoaTree", fields: [parentId], references: [id])
  children     ChartOfAccount[] @relation("CoaTree")
  isOnBalance  Boolean          @default(true) // فصل أموال العملاء (On) عن عمولات الوسيط (Off)
  isLocked     Boolean          @default(false) // المستوى 1/2 مقفل
  accountType  String? // asset | liability | revenue | expense | equity
  clientId     String? // حساب تحليلي مرتبط بعميل (يُفتح عند الاعتماد)
  costCenterId String?

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([parentId])
}

// مراكز التكلفة — 3 مستويات تبدأ بالفرع
model CostCenter {
  id       String       @id @default(cuid())
  tenantId String
  tenant   Tenant       @relation(fields: [tenantId], references: [id])
  code     String
  name     String
  level    Int          @default(1) // 1=فرع
  parentId String?
  parent   CostCenter?  @relation("CcTree", fields: [parentId], references: [id])
  children CostCenter[] @relation("CcTree")

  @@unique([tenantId, code])
  @@index([tenantId])
}

// السندات: قيد (JRV)، صرف (PYV)، قبض (RCV)، دفع مباشر (DPV) — يدوي أو مولّد آلياً
model Voucher {
  id         String      @id @default(cuid())
  tenantId   String
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  type       VoucherType
  sequenceNo String?
  amount     Decimal?    @db.Decimal(16, 2)
  status     String?     @default("draft")
  isAuto     Boolean     @default(false) // مولّد آلياً من الإنتاج
  reference  String? // مرجع (policyId/invoiceId…)
  lines      Json? // أطراف القيد (debit/credit)
  createdAt  DateTime    @default(now())

  @@index([tenantId])
}

enum VoucherType {
  JRV // قيد يومية
  PYV // صرف
  RCV // قبض
  DPV // دفع مباشر
}

// الفاتورة الضريبية الصادرة من الوسيط — عمولة على المؤمِّن (COMMISSION) أو رسوم خدمة على العميل (FEES). بنية ممهّدة لـ ZATCA.
model Invoice {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  sequenceNo  String?
  kind        String?  @default("COMMISSION") // COMMISSION (على المؤمِّن) | FEES (رسوم خدمة على العميل)
  insurerName String? // للفاتورة على المؤمِّن (عمولة)
  clientId    String? // للفاتورة على العميل (رسوم خدمة)
  policyId    String?
  netAmount   Decimal? @db.Decimal(14, 2)
  vatAmount   Decimal? @db.Decimal(14, 2)
  totalAmount Decimal? @db.Decimal(14, 2)
  status      String?  @default("draft")
  zatcaUuid   String?
  zatcaHash   String? // تمهيد ZATCA (Fatoora)
  qrPayload   String?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, clientId])
}

// إشعار مدين/دائن للعميل (يُولَّد عند الاعتماد المالي)
model DebitNote {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  sequenceNo    String?
  clientId      String?
  policyId      String?
  netAmount     Decimal?  @db.Decimal(14, 2)
  vatAmount     Decimal?  @db.Decimal(14, 2)
  settledAmount Decimal   @default(0) @db.Decimal(14, 2) // المُحصَّل من العميل عبر سندات القبض (RCV)
  settledAt     DateTime? // تاريخ اكتمال التحصيل (settledAmount ≥ الإجمالي)
  createdAt     DateTime  @default(now())

  @@index([tenantId])
  @@index([tenantId, clientId])
}

// قسط ضمن خطة تقسيط إشعار مدين — التحصيل الجزئي يُطبَّق عليها بالأقدم استحقاقًا (waterfall).
model Installment {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  debitNoteId   String
  clientId      String?
  policyId      String?
  seq           Int // ترتيب القسط 1..N
  dueDate       DateTime
  amount        Decimal   @db.Decimal(14, 2)
  settledAmount Decimal   @default(0) @db.Decimal(14, 2)
  settledAt     DateTime?
  remindedAt    DateTime? // حتمية التذكير (لا يتكرّر)
  createdAt     DateTime  @default(now())

  @@index([tenantId])
  @@index([debitNoteId, seq])
  @@index([tenantId, clientId])
}

// طلب تواصل مبيعات (Lead) قبل التسجيل — للباقات الكبيرة/المؤسسات. مستوى منصّة (بلا tenantId).
model Lead {
  id        String   @id @default(cuid())
  name      String
  company   String?
  email     String
  phone     String?
  planCode  String?
  seats     Int?
  message   String?
  status    String?  @default("new") // new | contacted | closed
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// قالب نموذج ديناميكي قابل لإعادة الاستخدام — بيانات أساسية + كتل معبّأة مسبقًا لخطّ منتج.
model FormTemplate {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  name            String
  productLineCode String
  description     String?
  base            Json // حقول أساسية معبّأة مسبقًا
  blocks          Json? // صفوف كتل معبّأة مسبقًا (اختياري)
  usageCount      Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, productLineCode])
}

// سجلّ المنتِجين (الوسطاء الفرعيون) — من يجلب الأعمال مقابل حصّة من عمولة الوسيط.
model Producer {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  code           String? // PRD-0001
  name           String
  type           String?  @default("INDIVIDUAL") // INDIVIDUAL | COMPANY
  licenseNo      String? // رقم ترخيص هيئة التأمين (منتِج مرخّص)
  crNumber       String?
  nationalId     String?
  email          String?
  phone          String?
  iban           String? // للتسوية/الدفع
  commissionRate Decimal? @db.Decimal(6, 3) // نسبة عمولة المنتِج من عمولة الوسيط (%) — افتراضية
  status         String?  @default("active") // active | suspended
  notes          String?
  createdAt      DateTime @default(now())

  @@index([tenantId])
}

// إشعار دائن: CNP = قسط مُرتجَع للعميل (إلغاء)؛ CNC = عكس عمولة على المؤمِّن (إلغاء).
model CreditNote {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  sequenceNo      String?
  kind            String?   @default("CNP") // CNP (على العميل: قسط مُرتجَع) | CNC (على المؤمِّن: عكس عمولة)
  clientId        String? // للإشعار الدائن على العميل
  insurerName     String? // للإشعار الدائن على المؤمِّن (عكس العمولة)
  policyId        String?
  netAmount       Decimal?  @db.Decimal(14, 2)
  vatAmount       Decimal?  @db.Decimal(14, 2)
  // صرف المرتجع الفعلي للعميل (§1.7) — الإشعار الدائن يخفض الذمّة؛ الصرف يدفعها نقدًا
  refundedAt      DateTime?
  refundVoucherId String?
  createdAt       DateTime  @default(now())

  @@index([tenantId])
}

// ============================================================
// ZATCA المرحلة 2 (Fatoora / Integration) — جاهزية متعددة المستأجرين
// ============================================================

enum ZatcaEnvironment {
  SANDBOX
  PRE_PRODUCTION
  PRODUCTION
}

/// حالة تهيئة المستأجر مع ZATCA (Fatoora Onboarding).
enum ZatcaOnboardingStatus {
  NOT_STARTED
  CSR_GENERATED
  COMPLIANCE_PASSED
  ACTIVE
}

/// هوية ZATCA التشفيرية وإعدادات الوساطة (broker settings) المستقلّة لكل مستأجر — معزولة منطقياً.
/// تجمع: بيانات المورِّد + بيانات الاعتماد المشفّرة + حالة التهيئة + عدّاد وتجزئة معزولَين بالمستأجر.
model TenantZatcaConfig {
  id                String                @id @default(cuid())
  tenantId          String                @unique
  tenant            Tenant                @relation(fields: [tenantId], references: [id])
  vatNumber         String // 15 رقماً تبدأ وتنتهي بـ 3 (يُتحقَّق في الخدمة)
  businessNameAr    String
  businessNameEn    String?
  environment       ZatcaEnvironment      @default(SANDBOX)
  // EGS (حل توليد الفواتير الإلكترونية) + حالة التهيئة
  egsSerialNumber   String? // رقم تسلسلي فريد لوحدة EGS
  onboardingStatus  ZatcaOnboardingStatus @default(NOT_STARTED)
  // مفاتيح/شهادات مشفّرة at-rest (AES-256-GCM) — تُخزَّن نصاً مشفّراً لا خاماً أبداً
  privateKeyEnc     String?               @db.Text // المفتاح الخاص (ECDSA secp256k1)
  csrPem            String?               @db.Text // طلب توقيع الشهادة (CSR)
  complianceCsidEnc String?               @db.Text // شهادة الامتثال المؤقتة (CCSID)
  productionCsidEnc String?               @db.Text // شهادة الإنتاج الدائمة (PCSID)
  publicKey         String?               @db.Text
  lastActivatedAt   DateTime?
  // تسلسل وسلسلة تجزئة معزولان بالمستأجر (anti-tampering)
  invoiceCounter    Int                   @default(0)
  lastDocumentHash  String? // تجزئة SHA-256 (Base64) لآخر مستند صادر لهذا المستأجر
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([tenantId])
}

enum BillingDocType {
  TAX_INVOICE // فاتورة ضريبية (عمولة على شركات التأمين) — B2B
  DEBIT_NOTE // إشعار مدين (قسط على العميل)
  CREDIT_NOTE // إشعار دائن (استرداد/إلغاء)
}

enum BillingSubtype {
  STANDARD_B2B
  SIMPLIFIED_B2C
}

/// مستند فوترة موحّد متوافق مع ZATCA (يُغني عن Invoice/DebitNote/CreditNote المبسّطة).
/// عدّاد وتجزئة وتسلسل معزولة بالمستأجر + UUIDv4 عالمي + حِمل QR (TLV) و UBL (JSON).
model BillingDocument {
  id                 String         @id @default(cuid())
  tenantId           String
  tenant             Tenant         @relation(fields: [tenantId], references: [id])
  uuid               String // UUIDv4 عالمي فريد
  documentType       BillingDocType
  invoiceSubtype     BillingSubtype @default(STANDARD_B2B)
  serialNumber       String // DNP-RUH-2026-JAN-10001
  counter            Int // تسلسل معزول بالمستأجر
  previousHash       String? // سلسلة التجزئة — تجزئة المستند السابق لنفس المستأجر
  hash               String // SHA-256 (Base64) لهذا المستند
  qrTlv              String         @db.Text // Base64 TLV (الوسوم 1–5، و6/7 للمرحلة 2)
  xmlPayload         Json? // بنية تُحاكي UBL 2.1 (للتسلسل في المرحلة 9)
  issueDate          String // YYYY-MM-DD
  issueTimestamp     String // ISO 8601 (مع HH:MM:SS)
  supplyDate         String? // تاريخ بدء التغطية
  // المورِّد (لقطة من TenantZatcaConfig وقت الإصدار)
  supplierName       String
  supplierVat        String
  // العميل/المستلم
  customerName       String?
  customerVat        String?
  customerCrOrId     String?
  customerAddress    String?
  clientId           String?
  policyId           String?
  // البنود والإجماليات
  lineItems          Json // [{ description, qty, unitPrice, discount, vatRate, vatAmount, net }]
  totalExclVat       Decimal        @db.Decimal(14, 2)
  totalVat           Decimal        @db.Decimal(14, 2)
  totalInclVat       Decimal        @db.Decimal(14, 2)
  // مراجع التسوية (إشعارات مدين/دائن)
  billingReferenceId String? // UUID الفاتورة الأصلية المُعدَّلة
  reasonForIssuance  String? // مطلوب من ZATCA للإشعارات
  status             String         @default("ISSUED")
  // توجيه ZATCA: B2B = مقاصة فورية (Clearance) · B2C = إبلاغ خلال 24س (Reporting)
  zatcaFlow          String? // CLEARANCE | REPORTING
  zatcaStatus        String         @default("PENDING") // PENDING | CLEARED | REPORTED | FAILED
  zatcaStampB64      String?        @db.Text // الختم التشفيري المُعاد من ZATCA (Clearance)
  zatcaReportedAt    DateTime?
  createdAt          DateTime       @default(now())

  @@unique([uuid])
  @@unique([tenantId, counter]) // عدّاد معزول بالمستأجر
  @@unique([tenantId, serialNumber])
  @@index([tenantId])
  @@index([clientId])
  @@index([policyId])
}

/// قيد عمولة وساطة (لكل وثيقة) — أساس تقرير العمولات وتسويتها مع شركات التأمين.
/// status: accrued (مستحقّة، لم تُستلم) | received (مستلمة) | variance (فرق عن المتوقّع).
model Commission {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  policyId       String?
  insurerName    String?
  clientName     String?
  productLine    String?
  rate           Decimal? @db.Decimal(6, 3)
  amount         Decimal  @db.Decimal(12, 2) // العمولة المتوقّعة
  receivedAmount Decimal? @db.Decimal(12, 2) // المُستلم فعلاً
  status         String?  @default("accrued")
  periodMonth    String? // 2026-01
  createdAt      DateTime @default(now())

  @@index([tenantId])
}

// ============================================================
// التحقق الحكومي والأرصدة
// ============================================================

model VerificationProvider {
  id     String              @id @default(cuid())
  key    String              @unique // nafath | yaqeen | wathiq | spl
  name   String
  checks VerificationCheck[]
}

model VerificationCheck {
  id         String               @id @default(cuid())
  tenantId   String
  tenant     Tenant               @relation(fields: [tenantId], references: [id])
  providerId String
  provider   VerificationProvider @relation(fields: [providerId], references: [id])
  checkType  String // identity | cr | ubo | mobile | address | pep_sanctions
  status     String // success | failed | pending
  cost       Decimal?             @db.Decimal(8, 2)
  resultRef  String? // ملخّص/مرجع نتيجة
  clientId   String? // ربط بالعميل
  requestId  String? // ربط بالطلب
  riskLevel  String? // low | medium | high (لفحص PEP/العقوبات)
  createdAt  DateTime             @default(now())

  @@index([tenantId])
}

model Wallet {
  id       String              @id @default(cuid())
  tenantId String
  tenant   Tenant              @relation(fields: [tenantId], references: [id])
  service  String // yaqeen | wathiq | nafath
  balance  Int                 @default(0) // عدد العمليات المتبقية
  ledger   TransactionLedger[]

  @@unique([tenantId, service])
}

model TransactionLedger {
  id        String   @id @default(cuid())
  walletId  String
  wallet    Wallet   @relation(fields: [walletId], references: [id])
  delta     Int // + شحن / - خصم
  reason    String
  createdAt DateTime @default(now())
}

// ============================================================
// المستندات والتدقيق
// ============================================================

/// عدّاد استهلاك التخزين لكل مستأجر (المرحلة D1) — أساس الحجز الذرّي والتلميتري.
/// `usedBytes` يُزاد ذرّياً عند الحجز ويُطابَق عند التأكيد؛ الحدّ من entitlement `storage.quotaMb`.
model TenantStorage {
  tenantId  String   @unique
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  usedBytes BigInt   @default(0)
  fileCount Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Document {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  storageKey String // tenant_{id}/...
  fileName   String
  mime       String
  sizeBytes  Int
  hash       String
  docType    DocType  @default(ATTACHMENT)
  entityType String // client | policy_request | claim ...
  entityId   String
  rowId      String? // ربط بصفّ متكرر (تابع/مركبة)
  createdAt  DateTime @default(now())

  @@index([tenantId])
}

enum DocType {
  ATTACHMENT
  OFFICIAL
}

// سجل التدقيق — غير قابل للتعديل أو الحذف (immutable) يُفرض في طبقة Prisma.
// يلتقط: المستخدم، الإجراء، الكيان، عنوان IP، الجهاز، والوقت (مطلب NCA ECC).
model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    String?
  action    String // login | create | update | delete | file_url | verify | approve
  entity    String
  entityId  String?
  ipAddress String? // عنوان IP للطلب (يراعي X-Forwarded-For خلف العاكس)
  userAgent String? // بصمة الجهاز/المتصفح
  meta      Json?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([createdAt])
}
